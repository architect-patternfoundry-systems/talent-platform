# Database
DATABASE_URL=postgresql://user:password@localhost:5432/talent_platform
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/talent_platform_test

# Authentication
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OIDC
OIDC_ISSUER=https://your-oidc-provider.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback

# Application
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=info

# Governance
NVEDO_EMAIL=nvedo@example.com
DATA_GOVERNANCE_EMAIL=data_governance@example.com
HR_BUSINESS_PARTNER_EMAIL=hr@example.com

# Rate Limiting
RATE_LIMIT_PER_HOUR=1000
